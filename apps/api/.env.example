# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/studyos

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional. The API validates user tokens through Supabase Auth by default.
# Only needed if you switch back to local JWT verification.
SUPABASE_JWT_SECRET=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Embedding model (HuggingFace BGE)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# Storage (Supabase Storage)
STORAGE_BUCKET=studyos-documents

# CORS
ALLOWED_ORIGINS=http://localhost:3000
